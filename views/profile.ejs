<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
</head>

<body class="bg-zinc-900 text-white flex">
    <div class="px-10 py-15 h-full w-full ">
        <div class="flex justify-end">
            <a class="bg-red-500 rounded-md px-3 py-2 text-sm mb-5 inline-block" href="/logout">Logout</a>
        </div>
        <div class="flex gap-2 mb-2">
            <div class="w-10 h-10 rounded bg-transparent overflow-hidden">
                <a href="/profile/ <% upload  %>"> <img class="w-full h-full object-cover" src="/images/<%= user.profilepic %>" alt=""></a>
               
            </div>

            <h2 class="mb-2  font-bold">Hello <%= user.username %>
            </h2>
        </div>

        <form action="/post" method="post">
            <textarea class="resize-none block border-2 border-zinc-600 rounded w-100 h-20 p-2 outline-none" required
                placeholder="what's in your mind? " name="content" id=""></textarea>
            <input class=" rounded py-2 text-sm w-40 px-3 mt-2 bg-blue-600 block" type="submit" value="create blog">
        </form>
        <div class="text-zinc-400 mt-5 mb-3">
            <h3>Your Posts</h3>

            <% user.posts.reverse().forEach(post=> { %>
                <% if(post){ %>
                    <div class="border rounded border-zinc-600 bg-zinc-700 p-3 w-100 mb-2">

                        <h4 class="text-blue-600" name="name">@<%= user.username %>
                        </h4>
                        <h5 class="tracking-tight">
                            <%= post.content %>
                        </h5>
                        <small class="">
                            <%= post.likes.length %> Likes
                        </small>
                        <div class="btns flex gap-4">
                            <a class="text-blue-500" href="/like/<%= post._id %>">
                                <%= post.likes.indexOf(user._id)===-1? "like" : "unlike" %>
                            </a>
                            <a class="text-zinc-400" href="/edit/<%= post._id  %>">Edit</a>
                        </div>

                    </div>
                    <% } %>

                        <% }); %>
        </div>
    </div>
</body>

</html>