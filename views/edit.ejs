<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
</head>
<body class="bg-zinc-900 text-white flex">
    <div class="px-10 py-15 h-full w-full " >
        <div class="flex justify-end">
            <a class="bg-red-500 rounded-md px-3 py-2 text-sm mb-5 inline-block" href="/logout">Logout</a>
        </div>
        <form action="/update/<%=post._id %>" method="post">
            <textarea class="resize-none block border-2 border-zinc-600 rounded w-100 h-20 p-2 outline-none" required placeholder="what's in your mind? " name="content" id=""><%= post.content  %></textarea>
            <input class=" rounded py-2 text-sm w-40 px-3 mt-2 bg-yellow-600 block" type="submit" value="update blog">
        </form>
       
        </div>
    </div>
</body>
</html>